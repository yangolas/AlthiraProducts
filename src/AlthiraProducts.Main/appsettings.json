{
  "Config": {

    "Logs": {
      "LogLevel": "Information"
    },

    "OpenTelemetry": {
      "ConnectionString": "(secret)",
      "WebApiName": "AlthiraProducts.WebApi",
      "ConsumerBrokerName": "AlthiraProducts.MessageBroker.Consumer",
      "OutboxWorkerName": "AlthiraProducts.Worker.Outbox",
      "AzureBlobStorageWorkerName": "AlthiraProducts.Worker.AzureBlobStorage"
    },

    "DatabaseRead": {
      "ConnectionString": "(secret)",
      "DatabaseName": "(secret)"
    },

    "DatabaseWrite": {
      "ConnectionString": "(secret)"
    },

    "MessageBroker": {
      "HostName": "(secret)",
      "UserName": "(secret)",
      "Password": "(secret)",
      "Port": 0,
      "ConsumerConcurrency": 0
    },

    "Events": {
      "ProductEventChannels": [
        {
          "EventName": "CreateProductEventCommand",
          "Exchange": "product_events_exchange",
          "RoutingKey": "product.create",
          "Queue": "queue.product.create",
          "RetryPolicy": {
            "MaxRetryAttempts": 3,
            "InitialDelaySeconds": 3,
            "BackoffMultiplier": 2
          }
        },
        {
          "EventName": "UpdateProductEventCommand",
          "Exchange": "product_events_exchange",
          "RoutingKey": "product.update",
          "Queue": "queue.product.update",
          "RetryPolicy": {
            "MaxRetryAttempts": 3,
            "InitialDelaySeconds": 3,
            "BackoffMultiplier": 2
          }
        },
        {
          "EventName": "DeleteProductEventCommand",
          "Exchange": "product_events_exchange",
          "RoutingKey": "product.delete",
          "Queue": "queue.product.delete",
          "RetryPolicy": {
            "MaxRetryAttempts": 3,
            "InitialDelaySeconds": 3,
            "BackoffMultiplier": 2
          }
        }
      ]
    },

    "Outbox": {
      "BatchSize": 100,
      "IntervalToPolling": "00:01:00",
      "RetryPolicy": {
        "MaxRetryAttempts": 3,
        "InitialDelay": "00:00:03",
        "BackoffMultiplier": 2
      }
    },

    "Assembly": {
      "AssemblyRepositoryRead": "AlthiraProducts.Adapters.Repository.Read",
      "AssemblyRepositoryWrite": "AlthiraProducts.Adapters.Repository.Write",
      "AssemblyImageValidator": "AlthiraProducts.Adapters.ImagesValidator",
      "AssemblyApplicationProduct": "AlthiraProducts.Products.Application"
    },

    "AzureBlobStorage": {
      "ConnectionString": "(Secret)",
      "ProductImageBlobContainer": {
        "Name": "product-images",
        "WorkerBatchSize": 100,
        "IntervalToPolling": "00:01:00",
        "RetryPolicy": {
          "MaxRetryAttempts": 3,
          "InitialDelay": "00:00:03",
          "BackoffMultiplier": 2
        }
      }

    }
  }
}